# LLM
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# Embeddings
EMBEDDINGS_MODEL=text-embedding-3-small

# ChromaDB
CHROMA_DB_PATH=./chroma_db
CHROMA_COLLECTION_NAME=veronica_knowledge
PLUGINS_DIR=./plugins

# Web search
TAVILY_API_KEY=
SERPER_API_KEY=

# Voice
VOICE_ENABLED=true
TTS_PROVIDER=openai
TTS_MODEL=tts-1
TTS_VOICE=alloy
ELEVENLABS_API_KEY=
STT_LANGUAGE=

# Policy
ACTION_AUDIT_LOG_PATH=./logs/action_audit.jsonl
MAX_TOOLS_PER_SESSION=5
MAX_PLUGIN_EXECUTIONS=100
